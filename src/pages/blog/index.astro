---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout>
  <section>
    <h1 class="text-3xl font-bold mb-8">Blog</h1>
    <div class="flex flex-col gap-4">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="block bg-white rounded-2xl p-6 md:p-8 hover:bg-gray-50 transition">
          <h2 class="text-xl font-bold">{post.data.title}</h2>
          <time class="text-sm text-gray-500 mt-2 block" datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </a>
      ))}
    </div>
  </section>
</Layout>
