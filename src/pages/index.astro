---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const latestPosts = posts.slice(0, 3);
---

<Layout>
	<Hero />
	<section>
		<div class="bg-white rounded-2xl p-6 md:p-8 flex flex-col gap-6">
			<h2 class="text-3xl font-bold">Blog</h2>
			<div class="flex flex-col gap-4">
				{latestPosts.map((post) => (
					<a href={`/blog/${post.id}`} class="group flex flex-col gap-1">
						<h2 class="text-xl font-bold text-blue-600 group-hover:underline">{post.data.title}</h2>
						<time class="text-sm text-gray-500" datetime={post.data.pubDate.toISOString()}>
							{post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
						</time>
					</a>
				))}
			</div>
			<a href="/blog" class="inline-flex items-center gap-2 px-4 py-2 border rounded-lg hover:bg-gray-50 transition self-start">
				ブログ一覧へ →
			</a>
		</div>
	</section>
</Layout>
